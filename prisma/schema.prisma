generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TeamMember {
  id          Int           @id @default(autoincrement())
  name        String
  jobTitle    String
  description String
  ptoStatus   Boolean       @default(false)
  active      Boolean       @default(true)

  skills      TeamMemberSkill[]
  assignments Assignment[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Skill {
  id        Int           @id @default(autoincrement())
  name      String
  skillCode String        @unique
  category  SkillCategory @default(clinical_skill)

  teamMembers TeamMemberSkill[]

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TeamMemberSkill {
  teamMemberId Int
  skillId      Int

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([teamMemberId, skillId])
  @@index([skillId])
}

model Workflow {
  id        Int               @id @default(autoincrement())
  status    String            @default("active")

  requests  WorkflowRequest[]
  tasks     WorkflowTask[]

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
}

model WorkflowRequest {
  id         Int            @id @default(autoincrement())
  workflowId Int?
  rawRequest String
  source     String         @default("user")

  workflow   Workflow?      @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  tasks      WorkflowTask[]

  createdAt  DateTime       @default(now())

  @@index([workflowId])
}

model WorkflowTask {
  id         Int              @id @default(autoincrement())
  workflowId Int
  requestId  Int?
  taskType   String
  sequence   Int
  status     String           @default("completed")
  input      Json?
  output     Json?
  reason     String?

  workflow   Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  request    WorkflowRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  assignment Assignment?

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([workflowId, sequence])
  @@index([workflowId])
  @@index([requestId])
  @@index([taskType])
}

model Assignment {
  id             Int          @id @default(autoincrement())
  teamMemberId   Int
  workflowTaskId Int          @unique
  summary        String

  teamMember     TeamMember   @relation(fields: [teamMemberId], references: [id], onDelete: Restrict)
  workflowTask   WorkflowTask @relation(fields: [workflowTaskId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([teamMemberId])
}

enum SkillCategory {
  specialty
  clinical_skill
  case_type
}
