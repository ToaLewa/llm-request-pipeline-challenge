# PostgreSQL connection used by Prisma, the backend, and seed scripts.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/llm_request_pipeline?schema=public"

# Backend bind settings.
HOST="0.0.0.0"
PORT="3000"

# Required only for OpenAI-backed routing, ranking, workflow actions, and summaries.
OPENAI_API_KEY=""

# Optional OpenAI model override. Defaults to gpt-4.1-mini when unset.
OPENAI_MODEL="gpt-4.1-mini"
